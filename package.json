{
  "name": "@albsugy/aos",
  "version": "0.5.1",
  "description": "Agent Operations Stack — portable spec, guardrails, audit, verification, and console for operating AI coding agents",
  "type": "module",
  "bin": {
    "aos": "dist/aos.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "npm run test:source && npm run test:bundle",
    "test:source": "bash test/smoke.sh",
    "test:bundle": "AOS_BIN=\"node $PWD/dist/aos.mjs\" bash test/smoke.sh",
    "build": "node scripts/build.mjs",
    "prepublishOnly": "npm run build && npm test",
    "release": "bash scripts/release.sh"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "files": [
    "dist",
    "assets",
    "install.sh",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/albsugy/aos.git"
  },
  "keywords": [
    "ai-agents",
    "claude-code",
    "agent-ops",
    "guardrails",
    "audit"
  ],
  "author": "Medhat Albsugy",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.28.1",
    "yaml": "^2.9.0"
  }
}
